{
    "require": {
        "firebase/php-jwt": "^7.0",
        "nikic/fast-route": "^1.3",
        "mongodb/mongodb": "^2.1",
        "vlucas/phpdotenv": "^5.6"
    },

    "autoload": {
        "classmap": [
            "core/",
            "model/",
            "pgServices/",
            "mongoServices/",
            "controllers/",
